# Step 1: Delete old cluster
kind delete cluster --name kind-cluster

# Step 2: Upgrade KIND
curl -Lo ./kind https://kind.sigs.k8s.io/dl/latest/kind-linux-amd64
chmod +x ./kind
sudo mv ./kind /usr/local/bin/kind

# Step 3: Verify
kind version

# Step 4: Create cluster again
kind create cluster --name kind-cluster --config=config.yml
